        <mxCell id="uxCVFWm02AGdhnOv2bi4-3" parent="1" style="text;html=0;strokeColor=none;fillColor=none;              fontSize=13;fontStyle=1;fontColor=#444444;align=left;fontSize=13;" value="[ FastAPI Service — Container: Python / FastAPI ]" vertex="1">
          <mxGeometry height="24" width="440" x="102" y="88" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-4" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="CorrelationIdMiddleware&#xa;[Component: Starlette Middleware]&#xa;&#xa;Gera ou propaga X-Correlation-ID.&#xa;Injeta no contexto async e nos logs&#xa;via structlog contextvars.&#xa;Coleta métricas de duração HTTP." vertex="1">
          <mxGeometry height="170" width="280" x="250" y="130" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-5" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="OrderRouter&#xa;[Component: FastAPI APIRouter]&#xa;&#xa;Valida schema Pydantic do payload.&#xa;Despacha para OrderService.&#xa;Mapeia is_idempotent para&#xa;HTTP 200 ou 201." vertex="1">
          <mxGeometry height="170" width="280" x="250" y="360" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-6" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="OrderService&#xa;[Component: Python class]&#xa;&#xa;Orquestra o fluxo: valida requester,&#xa;checa idempotência e persiste&#xa;ordem + outbox_event em transação&#xa;única. Trata race conditions&#xa;via IntegrityError." vertex="1">
          <mxGeometry height="190" width="280" x="250" y="584.5" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-7" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="OrderRepository&#xa;[Component: SQLAlchemy async]&#xa;&#xa;find_by_external_id para&#xa;checagem de idempotência.&#xa;create para persistência." vertex="1">
          <mxGeometry height="130" width="260" x="80" y="840" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-8" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="OutboxRepository&#xa;[Component: SQLAlchemy async]&#xa;&#xa;create para persistência do evento.&#xa;fetch_pending com SKIP LOCKED.&#xa;mark_processed / mark_failed." vertex="1">
          <mxGeometry height="130" width="260" x="470" y="840" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-9" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="RequesterClient&#xa;[Component: httpx AsyncClient]&#xa;&#xa;GET /requesters/{id} com timeout&#xa;configurável. Mapeia 404 para&#xa;RequesterNotFoundException e&#xa;5xx/timeout para&#xa;ServiceUnavailableException." vertex="1">
          <mxGeometry height="190" width="280" x="750" y="580" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-10" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="ExceptionHandlers&#xa;[Component: FastAPI handlers]&#xa;&#xa;Mapeia exceções de domínio para&#xa;HTTP status codes. Incrementa&#xa;orders_failed_total com&#xa;label error_type." vertex="1">
          <mxGeometry height="170" width="280" x="760" y="360" as="geometry" />
        </mxCell>
        <mxCell id="uxCVFWm02AGdhnOv2bi4-11" parent="1" style="rounded=1;arcSize=6;fillColor=#4a90d9;strokeColor=#2c5f8a;              fontColor=#ffffff;fontSize=12;align=center;whiteSpace=wrap;              verticalAlign=middle;html=0;" value="PrometheusMetrics&#xa;[Component: prometheus-client]&#xa;&#xa;Expõe /metrics. Contadores:&#xa;orders_created_total,&#xa;orders_failed_total,&#xa;http_request_duration_seconds." vertex="1">
          <mxGeometry height="170" width="280" x="760" y="130" as="geometry" />
        </mxCell>
