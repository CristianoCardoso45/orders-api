# ── Banco de dados ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=orders_db
DB_USER=orders_user
DB_PASSWORD=orders_pass

# ── AWS / LocalStack ──
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── SQS ──
SQS_QUEUE_NAME=orders-queue
SQS_DLQ_NAME=orders-dlq

# ── Secrets Manager ──
SECRETS_NAME=order-service-secrets

# ── Fallback secrets (usados quando Secrets Manager não está disponível) ──
API_KEY=dev-api-key

# ── Requester service ──
REQUESTER_SERVICE_URL=http://localhost:8001

# ── Observabilidade ──
OTEL_EXPORTER=console
LOG_LEVEL=DEBUG

OTEL_ENABLED=false

# ── Worker ──
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=10